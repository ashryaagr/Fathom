{
  "name": "fathom",
  "version": "1.0.6",
  "description": "A semantic-zoom PDF reader for research papers. Pinch with ⌘ on a passage — a full-screen lens opens with a streaming, grounded explanation from Claude.",
  "homepage": "https://github.com/ashryaagr/Fathom",
  "repository": {
    "type": "git",
    "url": "https://github.com/ashryaagr/Fathom.git"
  },
  "bugs": {
    "url": "https://github.com/ashryaagr/Fathom/issues"
  },
  "license": "MIT",
  "main": "out/main/index.js",
  "type": "module",
  "author": {
    "name": "Ashrya",
    "email": "ashryaagr@gmail.com"
  },
  "scripts": {
    "copy-pdfjs-assets": "mkdir -p src/renderer/public && rm -rf src/renderer/public/pdfjs-cmaps src/renderer/public/pdfjs-fonts src/renderer/public/pdfjs-wasm && cp -r node_modules/pdfjs-dist/cmaps src/renderer/public/pdfjs-cmaps && cp -r node_modules/pdfjs-dist/standard_fonts src/renderer/public/pdfjs-fonts && cp -r node_modules/pdfjs-dist/wasm src/renderer/public/pdfjs-wasm",
    "predev": "npm run copy-pdfjs-assets",
    "prebuild": "npm run copy-pdfjs-assets",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "build-icon": "node scripts/build-icon.mjs",
    "build-dmg-bg": "node scripts/build-dmg-bg.mjs",
    "build-hero": "node scripts/build-hero.mjs",
    "build-sample-figures": "node scripts/build-sample-figures.mjs",
    "build-sample": "npm run build-sample-figures && node scripts/build-sample-pdf.mjs",
    "dist:mac": "npm run build && electron-builder --mac --arm64 --config electron-builder.config.cjs",
    "dist:mac-intel": "npm run build && electron-builder --mac --x64 --config electron-builder.config.cjs",
    "dist:mac-both": "npm run build && electron-builder --mac --arm64 --x64 --config electron-builder.config.cjs"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.118",
    "@types/dompurify": "^3.0.5",
    "better-sqlite3": "^12.9.0",
    "dompurify": "^3.4.1",
    "electron-updater": "^6.8.3",
    "framer-motion": "^12.38.0",
    "katex": "^0.16.45",
    "pdfjs-dist": "^5.6.205",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.1",
    "@tailwindcss/vite": "^4.2.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "pdf-lib": "^1.17.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.6.3",
    "vite": "^6.0.0"
  }
}
